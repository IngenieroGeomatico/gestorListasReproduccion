# ─────────────────────────────────────────────────────────────────────────────
# Copia este fichero a .env y rellena solo lo que necesites.
# Guía detallada de cómo obtener cada valor: sección "Configuración" del README.
# ─────────────────────────────────────────────────────────────────────────────

# Deezer (recomendado: cookie ARL desde el navegador)
# DevTools (F12) → Application/Storage → Cookies → https://www.deezer.com → 'arl'
DEEZER_ARL=tu_arl_de_deezer

# Deezer (alternativa: email y contraseña — login automático, obtiene el ARL)
DEEZER_EMAIL=
DEEZER_PASSWORD=

# Deezer (alternativa: OAuth — crea una app en https://developers.deezer.com/myapps)
DEEZER_APP_ID=
DEEZER_APP_SECRET=
DEEZER_ACCESS_TOKEN=

# Spotify (Bearer token desde el navegador — opcional, para escritura, ~1h)
# DevTools (F12) → Network → filtra api.spotify.com → header 'authorization: Bearer <token>'
SPOTIFY_BEARER_TOKEN=

# Spotify (OAuth — crea una app en https://developer.spotify.com/dashboard)
# Redirect URI: http://localhost:8888/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube (OAuth — necesario SOLO para CREAR playlists en tu cuenta)
# 1. Proyecto en https://console.cloud.google.com/
# 2. Habilita "YouTube Data API v3"
# 3. Credenciales OAuth tipo "Aplicación de escritorio"
# 4. Genera el refresh token: YouTubeImporter.authenticate(auto_save=True)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
