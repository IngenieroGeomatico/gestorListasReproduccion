# Deezer (recomendado: cookie ARL desde el navegador)
DEEZER_ARL=tu_arl_de_deezer

# Deezer (alternativa: email y contraseña — login automático)
DEEZER_EMAIL=
DEEZER_PASSWORD=

# Deezer (alternativa: OAuth — requiere app en Deezer Developers)
DEEZER_APP_ID=
DEEZER_APP_SECRET=
DEEZER_ACCESS_TOKEN=

# Spotify (Bearer token desde el navegador — opcional, para escritura)
SPOTIFY_BEARER_TOKEN=

# Spotify (OAuth — requiere Premium, solo lectura pública sin él)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
